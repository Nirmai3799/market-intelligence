# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Database (Supabase) ────────────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → Database → Connection string
# Use the "URI" format. SQLAlchemy needs postgresql:// (not postgres://)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Cache (Upstash Redis) ──────────────────────────────────────────────────────
# Get from: Upstash console → your Redis database → .env tab
REDIS_URL=redis://default:[YOUR-PASSWORD]@[YOUR-HOST].upstash.io:6379

# ── AI ─────────────────────────────────────────────────────────────────────────
# Anthropic: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional — not actively used)
OPENAI_API_KEY=sk-...

# ── Market Data ────────────────────────────────────────────────────────────────
# NewsAPI: https://newsapi.org/register (free tier works)
NEWSAPI_KEY=your_newsapi_key_here

# Finnhub: https://finnhub.io/register (free tier works)
FINNHUB_API_KEY=your_finnhub_key_here

# ── Auth ───────────────────────────────────────────────────────────────────────
# Any long random string — used to sign JWTs
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_long_random_string

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000

# ── Email Alerts (optional) ────────────────────────────────────────────────────
# Uses Gmail SMTP with an App Password (not your regular Gmail password)
# Enable at: Google Account → Security → 2-Step Verification → App passwords
EMAIL_FROM=yourname@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=yourname@gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
